<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hk.simba.license.service.mapper.RetrainConfigMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.hk.simba.license.service.entity.RetrainConfig">
        <id column="id" property="id"/>
        <result column="position_type" property="positionType"/>
        <result column="city_code" property="cityCode"/>
        <result column="city_name" property="cityName"/>
        <result column="status" property="status"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="modify_by" property="modifyBy"/>
        <result column="modify_time" property="modifyTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, position_type, city_code, city_name, status, create_by, create_time, modify_by, modify_time, update_time
    </sql>

    <select id="findListByPositionType" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"></include> from retrain_config WHERE position_type = #{positionType}
    </select>

    <select id="getPageList" resultType="com.hk.simba.license.api.vo.RetrainConfigVO"
            parameterType="com.hk.simba.license.api.request.retrain.RetrainConfigQueryRequest">
        select id, position_type as positionType, GROUP_CONCAT(city_name) as cityNameStr, status, create_by as createBy,
        create_time as createTime, modify_by as modifyBy, modify_time as modifyTime from retrain_config
        <where>
            <if test="positionType != null">
                position_type = #{positionType}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        GROUP BY position_type
    </select>

    <select id="getInvalidConfigCityByPositionType" resultType="java.lang.String">
        select city_code as cityCode from retrain_config where status = 1 and position_type = #{positionType}
    </select>

    <delete id="deleteByPositionType">
        delete from retrain_config where position_type = #{positionType}
    </delete>

</mapper>
